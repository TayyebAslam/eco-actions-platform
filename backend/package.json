{
  "name": "eco-actions-platform",
  "version": "1.0.0",
  "description": "Eco Actions is a sustainability engagement ecosystem that gamifies eco-friendly actions for schools and students.",
  "main": "src/index.ts",
  "dependencies": {
    "axios": "1.13.2",
    "bcryptjs": "3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "2.8.5",
    "dayjs": "1.11.19",
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "express-rate-limit": "8.2.1",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "9.0.3",
    "knex": "^3.1.0",
    "morgan": "1.10.1",
    "multer": "2.0.2",
    "nodemailer": "7.0.12",
    "pg": "^8.17.1",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ua-parser-js": "^2.0.8",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.9",
    "@types/nodemailer": "^7.0.5",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ua-parser-js": "^0.7.39",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@types/xlsx": "^0.0.35",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "babel-jest": "^30.2.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "js-yaml": "^4.1.1",
    "lint-staged": "^16.2.7",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "undici-types": "^7.18.2"
  },
  "scripts": {
    "dev": "concurrently \"nodemon --exec \\\"node --disable-warning=DEP0169 --require ts-node/register\\\" src/index.ts\" \"docker-compose up postgres redis -d\"",
    "dev:no-redis": "concurrently \"nodemon --exec \\\"node --disable-warning=DEP0169 --require ts-node/register\\\" src/index.ts\" \"docker-compose up postgres -d\"",
    "start": "node --disable-warning=DEP0169 -r ts-node/register src/index.ts",
    "prestart": "npx knex migrate:latest",
    "build": "tsc",
    "knex": "npx knex --knexfile knexfile.ts",
    "migration": "bash src/scripts/run_migrations.sh",
    "lint": "eslint src/**/*.ts",
    "lint:ci": "eslint src/**/*.ts --max-warnings 0",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "redis:cli": "docker exec -it eco-actions-redis redis-cli",
    "redis:keys": "docker exec eco-actions-redis redis-cli KEYS '*'",
    "redis:clear": "docker exec eco-actions-redis redis-cli FLUSHALL",
    "redis:stats": "docker exec eco-actions-redis redis-cli INFO stats",
    "prepare": "husky"
  },
  "keywords": [
    "sustainability",
    "gamification",
    "education",
    "nodejs",
    "express",
    "typescript"
  ],
  "author": "Tayyeb Aslam",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix"
    ]
  }
}
