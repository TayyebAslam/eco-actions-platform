# ===========================================
# Backend Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values
# NEVER commit .env file to version control!

# Server Configuration
PORT=5000
NODE_ENV=development
APP_NAME="Eco Actions Platform"
BASE_URL=http://localhost:5000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=eco_actions_db

# JWT Configuration
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long
JWT_EXPIRE=2d

# Encryption Key (separate from JWT for better security)
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=your_32_character_encryption_key_here

# Frontend URLs
FRONTEND_URL=http://localhost:3000
ADMIN_BASE_URL=http://localhost:3000
RESET_BASE_URL=http://localhost:3000
NEXT_PUBLIC_DOMAIN_URL=http://localhost:3000

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# Cookie Configuration (optional)
# COOKIE_DOMAIN=.yourdomain.com

# Trust Proxy (set to true if behind a load balancer/reverse proxy)
TRUST_PROXY=false

# ===========================================
# Email Configuration
# ===========================================

# Email Provider: Choose between 'smtp' or 'brevo'
EMAIL_PROVIDER=smtp

# SMTP Configuration (if EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
VERIFICATION_EMAIL=your_email@gmail.com

# Brevo Configuration (if EMAIL_PROVIDER=brevo)
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=sender@yourdomain.com
BREVO_SENDER_NAME=Eco Actions

# ===========================================
# Swagger Documentation
# ===========================================
SWAGGER_BASE_URL_LOCAL=http://localhost:5000
SWAGGER_BASE_URL_STAG=https://staging-api.yourdomain.com
SWAGGER_BASE_URL_PROD=https://api.yourdomain.com

# Swagger Authentication (for production - optional)
# If set, Swagger will be protected with Basic Auth in production
# If not set, Swagger will be disabled in production
# SWAGGER_USER=admin
# SWAGGER_PASSWORD=your_secure_password

# ===========================================
# Logging
# ===========================================
# Options: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=debug

# Enable/disable console logging override
ENABLE_CONSOLE_LOG=true

# ===========================================
# Activity Logging (Admin Actions)
# ===========================================
# Enable/disable activity logging
ACTIVITY_LOG_ENABLED=true

# Log channel: single (one file) or daily (date-based rotation)
ACTIVITY_LOG_CHANNEL=daily

# Days to retain logs (only for daily channel)
ACTIVITY_LOG_DAYS=30

# ===========================================
# Redis Configuration (for caching)
# ===========================================
# Redis is optional - app works without it but with reduced performance
# When using Docker Compose, set REDIS_HOST=redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password  # Only if Redis requires auth

# ===========================================
# Firebase Cloud Messaging (FCM)
# ===========================================
# Firebase is optional - push notifications are disabled without it
# Option 1: Path to Firebase service account JSON key file
# Download from Firebase Console > Project Settings > Service Accounts
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Option 2: Inline credentials (for Docker/cloud deployments)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
